NODE_ENV=production
PORT=5000
CLIENT_URL=https://your-vercel-app.vercel.app

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/trusonhub_portfolio

JWT_SECRET=generate_a_64_char_random_string
JWT_EXPIRES_IN=7d

ADMIN_EMAIL=your@email.com
VITE_ADMIN_EMAIL=your@email.com
ADMIN_PHONE=+2341234567890
ADMIN_PASSWORD=YourStrongPassword123!

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_brevo_smtp_user
SMTP_PASS=your_brevo_smtp_password
SMTP_FROM_NAME=YourName
SMTP_FROM_EMAIL=your@email.com
SMTP_REPLY_TO=your@email.com

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

VITE_API_URL=https://your-render-backend.onrender.com/api

MEDIA_STORAGE_DRIVER=mongodb
UPLOAD_STORAGE_DRIVER=mongodb
